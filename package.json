{
  "name": "vitepress-daisyui-theme",
  "version": "0.1.0",
  "description": "A VitePress theme skinned with DaisyUI 5 (on Tailwind CSS 4). Doc + page layouts, full DefaultTheme.Config compatibility, built-in local search, i18n, breadcrumb, team page, math.",
  "homepage": "https://github.com/ideamans/vitepress-daisyui-theme",
  "repository": {
    "type": "git",
    "url": "https://github.com/ideamans/vitepress-daisyui-theme.git"
  },
  "type": "module",
  "license": "MIT",
  "author": "miyanaga <miyanaga@ideamans.com>",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./styles": "./src/styles/theme.css",
    "./config": {
      "types": "./src/config.d.ts",
      "default": "./src/config.mjs"
    },
    "./components/*": "./src/components/*"
  },
  "files": [
    "src",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "example": "pnpm --filter vitepress-daisyui-theme-example dev"
  },
  "dependencies": {
    "minisearch": "^7.0.0"
  },
  "peerDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "daisyui": "^5.0.0",
    "tailwindcss": "^4.0.0",
    "vitepress": ">=1.0.0",
    "vue": "^3.3.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.13",
    "@types/node": "^22.10.1",
    "daisyui": "^5.0.0",
    "tailwindcss": "^4.1.13",
    "typescript": "^5.6.3",
    "vitepress": "^1.5.0",
    "vue": "^3.5.13"
  },
  "keywords": [
    "vitepress",
    "vitepress-theme",
    "daisyui",
    "tailwindcss",
    "documentation",
    "docs-theme"
  ]
}
